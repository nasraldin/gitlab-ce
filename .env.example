# ==============================================================================
# GitLab CE - Environment configuration
# Copy this file to `.env` and adjust the values for your deployment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Image
# ------------------------------------------------------------------------------
# Pin to a specific version for reproducible/production deployments.
# Find tags at: https://hub.docker.com/r/gitlab/gitlab-ce/tags
GITLAB_IMAGE=gitlab/gitlab-ce
GITLAB_VERSION=latest

# ------------------------------------------------------------------------------
# Networking / URLs
# ------------------------------------------------------------------------------
# The externally reachable hostname (and scheme) users will browse to.
# For local testing keep it as the host below; for production use your FQDN
# e.g. https://gitlab.example.com
GITLAB_HOSTNAME=gitlab.local
GITLAB_EXTERNAL_URL=http://gitlab.local:8929

# Host ports mapped to the container (host:container).
# Non-standard ports avoid clashing with anything already using 80/443/22.
GITLAB_HTTP_PORT=8929
GITLAB_HTTPS_PORT=8443
GITLAB_SSH_PORT=2224
# Git over SSH advertised port (should match GITLAB_SSH_PORT).
GITLAB_SHELL_SSH_PORT=2224

# ------------------------------------------------------------------------------
# Initial root password (optional)
# ------------------------------------------------------------------------------
# If unset, GitLab generates a random password stored (for 24h) at:
#   /etc/gitlab/initial_root_password  inside the container.
# Must be at least 8 characters. Do NOT commit a real secret to git.
GITLAB_ROOT_PASSWORD=

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------
TZ=UTC

# ------------------------------------------------------------------------------
# Resource limits (see docker-compose.yml)
# GitLab CE minimum: 4 vCPU / 4 GB RAM. Recommended: 8 GB RAM.
# ------------------------------------------------------------------------------
GITLAB_CPU_LIMIT=6
GITLAB_MEM_LIMIT=8g
GITLAB_CPU_RESERVATION=2
GITLAB_MEM_RESERVATION=4g

# Performance tuning (lower these on constrained hosts).
GITLAB_PUMA_WORKERS=2
GITLAB_SIDEKIQ_CONCURRENCY=10
GITLAB_POSTGRES_SHARED_BUFFERS=256MB

# ==============================================================================
# Container Registry
# ------------------------------------------------------------------------------
# The registry is served over plain HTTP on this port for local use. Because
# it is HTTP (not HTTPS), Docker clients must treat it as an "insecure registry"
# (see README). It is reachable inside the compose network via the alias
# `gitlab.local`, and from your host once you add it to /etc/hosts.
# ==============================================================================
GITLAB_REGISTRY_PORT=5050
GITLAB_REGISTRY_EXTERNAL_URL=http://gitlab.local:5050

# ==============================================================================
# GitLab Runner fleet
# ------------------------------------------------------------------------------
# Five runner containers (gitlab-runner, gitlab-runner-01 .. gitlab-runner-04)
# are defined in docker-compose.yml and AUTO-REGISTERED on first `up` by the
# `runner-bootstrap` service. No manual registration is needed.
# ==============================================================================
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner
GITLAB_RUNNER_VERSION=latest

# How runners reach GitLab from inside the compose network (service name).
CI_INTERNAL_URL=http://gitlab:8929

# Jobs run in parallel PER runner container. With 5 containers, the fleet's
# total parallelism is 5 x RUNNER_CONCURRENT. Raise for a busier monorepo.
RUNNER_CONCURRENT=4

# Tags applied to every runner (they also run untagged jobs).
RUNNER_TAGS=docker,monorepo
# Default image used for jobs that don't specify one.
RUNNER_DEFAULT_IMAGE=docker:27-cli

# Per-runner-container resource limits.
RUNNER_CPU_LIMIT=2
RUNNER_MEM_LIMIT=2g

# ==============================================================================
# MinIO (S3-compatible object storage)
# ------------------------------------------------------------------------------
# MinIO stores:
#   * GitLab blobs (CI artifacts, LFS, uploads, packages, registry layers, …)
#   * GitLab Runner distributed cache
# Buckets are auto-created by minio-setup on every `up`.
# Console: http://localhost:9001  (credentials below)
# ==============================================================================
MINIO_IMAGE=minio/minio
MINIO_IMAGE_VERSION=latest
MINIO_MC_IMAGE=minio/mc
MINIO_ROOT_USER=gitlab-minio
MINIO_ROOT_PASSWORD=ChangeMe_MinioP@ss!
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# GitLab object-storage buckets (one per object type — GitLab best practice)
GITLAB_OBJECT_BUCKET_ARTIFACTS=gitlab-artifacts
GITLAB_OBJECT_BUCKET_LFS=gitlab-lfs
GITLAB_OBJECT_BUCKET_UPLOADS=gitlab-uploads
GITLAB_OBJECT_BUCKET_PACKAGES=gitlab-packages
GITLAB_OBJECT_BUCKET_DEPENDENCY_PROXY=gitlab-dependency-proxy
GITLAB_OBJECT_BUCKET_TERRAFORM_STATE=gitlab-terraform-state
GITLAB_OBJECT_BUCKET_CI_SECURE_FILES=gitlab-ci-secure-files
GITLAB_OBJECT_BUCKET_PAGES=gitlab-pages
GITLAB_OBJECT_BUCKET_EXTERNAL_DIFFS=gitlab-external-diffs
GITLAB_OBJECT_BUCKET_REGISTRY=gitlab-registry

# Runner distributed cache bucket
RUNNER_CACHE_BUCKET=runner-cache
